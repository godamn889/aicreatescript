import os
import io
from functools import wraps
from flask import (
    Flask, render_template_string, request,
    redirect, url_for, send_file, jsonify, Response, session
)
from openai import OpenAI
import secrets
from datetime import datetime

# ──────────────────────────────────────────────
# CONFIGURATION – SET THESE VALUES HERE
# (or use environment variables on your host)
# ──────────────────────────────────────────────
OPENROUTER_API_KEY = os.environ.get("OPENROUTER_API_KEY", "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")
SITE_PASSWORD = os.environ.get("SITE_PASSWORD", "SECRET8239393AI0000S;S;DS'';;'[]P['][][]")
SECRET_KEY = os.environ.get("SECRET_KEY", secrets.token_hex(32))
SHARED_SECRET = os.environ.get("SHARED_SECRET", secrets.token_hex(16))

# ──────────────────────────────────────────────
app = Flask(__name__)
app.secret_key = SECRET_KEY
app.config['MAX_CONTENT_LENGTH'] = 200 * 1024 * 1024  # 200 MB max

openrouter = OpenAI(
    base_url="https://openrouter.ai/api/v1",
    api_key=OPENROUTER_API_KEY,
)

# Latest generated script in memory
latest_script = {"code": "", "game_link": "", "timestamp": ""}

# ──────────────────────────────────────────────
# Password protection decorator
# ──────────────────────────────────────────────
def require_password(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        if session.get("authenticated"):
            return f(*args, **kwargs)

        auth = request.authorization
        if auth and auth.password == SITE_PASSWORD:
            session["authenticated"] = True
            return f(*args, **kwargs)

        return Response(
            "Please log in to access this page.",
            401,
            {"WWW-Authenticate": 'Basic realm="Private Script Generator"'}
        )
    return decorated

# ──────────────────────────────────────────────
# Routes
# ──────────────────────────────────────────────
@app.route("/")
@require_password
def index():
    return render_template_string(HTML_TEMPLATE)

@app.route("/generate", methods=["POST"])
@require_password
def generate():
    game_link = request.form.get("game_link", "")
    describe = request.form.get("describe", "")

    # Get game info from text field or uploaded .txt file
    game_info = request.form.get("game_info", "")
    uploaded_file = request.files.get("game_file")

    if uploaded_file and uploaded_file.filename.endswith(".txt"):
        game_info = uploaded_file.read().decode("utf-8", errors="ignore")

    if not game_link or not describe or not game_info:
        return jsonify({"error": "Missing fields"}), 400

    system_prompt = (
        "You are a helpful assistant that writes Roblox Luau scripts. "
        "Always output clean, well-commented, working Luau code. "
        "Only return the script, no extra explanation."
    )
    user_prompt = (
        f"Game: {game_link}\n\n"
        f"Game‑specific details (workspace, remotes, etc.):\n{game_info}\n\n"
        f"Task: {describe}\n\n"
        "Write a Luau script that accomplishes the task, using the provided game details."
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_prompt}
    ]

    full_code = ""
    try:
        stream = openrouter.chat.completions.create(
            model="anthropic/claude-opus-4.7",
            messages=messages,
            stream=True,
            extra_headers={
                "HTTP-Referer": "http://localhost",
                "X-Title": "Private Roblox Script Generator"
            }
        )
        for chunk in stream:
            content = chunk.choices[0].delta.content
            if content:
                full_code += content

        latest_script["code"] = full_code
        latest_script["game_link"] = game_link
        latest_script["timestamp"] = datetime.now().isoformat()

        return jsonify({
            "success": True,
            "script": full_code,
            "game_link": game_link
        })

    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route("/download")
@require_password
def download():
    code = latest_script.get("code", "")
    if not code:
        return "No script generated yet.", 404
    return send_file(
        io.BytesIO(code.encode("utf-8")),
        mimetype="text/plain",
        as_attachment=True,
        download_name="script.lua"
    )

@app.route("/api/latest-script")
def api_latest_script():
    """For the Roblox executor to fetch the latest script."""
    secret = request.headers.get("X-Shared-Secret", "")
    if secret != SHARED_SECRET:
        return jsonify({"error": "Unauthorized"}), 403

    return jsonify({
        "script": latest_script.get("code", ""),
        "game_link": latest_script.get("game_link", ""),
        "timestamp": latest_script.get("timestamp", "")
    })

